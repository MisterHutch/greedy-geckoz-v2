# Exclude specific Node.js script directories only
/tools/
/scripts/

# Exclude individual problematic JS files (not ALL js files)
/tools/*.js
/scripts/*.js
integrate-ipfs-data.js
ipfs-direct-upload.js
simple-*.js
upload-*.js
test-*.js

# Exclude development and build artifacts
.env.local
.env
node_modules/
.next/
.git/
*.log
*.psd

# Exclude asset files that are too large  
/assets/geckoz/images/*.png
/assets/images/

# Clear any potential caches
.next/cache/
.swc/