{
  "version": 2,
  "framework": "nextjs",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "env": {
    "NEXT_PUBLIC_RPC_ENDPOINT": "@next_public_rpc_endpoint",
    "NEXT_PUBLIC_NETWORK": "@next_public_network",
    "NEXT_PUBLIC_IPFS_GATEWAY": "@next_public_ipfs_gateway"
  },
  "functions": {
    "app/**/*.{js,ts,tsx}": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}