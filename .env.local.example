# Pinata IPFS Configuration
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here

# Solana Configuration
NEXT_PUBLIC_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_TREASURY_WALLET=Cs3etBd1Mw9xptSgFZFmcK41PALcm1XHX6yHmS5HsPLY

# Metaplex Configuration (update after collection deployment)
NEXT_PUBLIC_COLLECTION_NFT_ADDRESS=your_collection_nft_address_here

# Local generation layers (optional; used by server-side generator)
# Provide an absolute path on your build machine or leave unset in Vercel
# For Vercel, store GECKO_LAYERS_PATH as a Project Environment Variable if needed
GECKO_LAYERS_PATH=/absolute/path/to/GreedyGeckoz_Layers
